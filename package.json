{
  "name": "tributos-br",
  "version": "0.1.0",
  "description": "Motor de cálculo tributário brasileiro com precisão decimal arbitrária",
  "license": "MIT",
  "author": {
    "name": "Vilson Padilha",
    "url": "https://github.com/vilsonneto"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vilsonneto/tributos-br.git"
  },
  "bugs": {
    "url": "https://github.com/vilsonneto/tributos-br/issues"
  },
  "homepage": "https://vilsonneto.github.io/tributos-br",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./precision": {
      "import": { "types": "./dist/precision/index.d.ts", "default": "./dist/precision/index.js" },
      "require": { "types": "./dist/precision/index.d.cts", "default": "./dist/precision/index.cjs" }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "tributario", "fiscal", "icms", "ipi", "nfe", "nota-fiscal",
    "brasil", "precisao", "decimal", "arredondamento", "sefaz"
  ],
  "engines": { "node": ">=18" }
}
