{
  "name": "tributos-br",
  "version": "1.3.0",
  "description": "Motor de cálculo tributário brasileiro com precisão decimal arbitrária",
  "license": "MIT",
  "author": {
    "name": "Vilson Padilha",
    "url": "https://github.com/vilsonneto"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vilsonneto/tributos-br.git"
  },
  "bugs": {
    "url": "https://github.com/vilsonneto/tributos-br/issues"
  },
  "homepage": "https://vilsonneto.github.io/tributos-br",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./precision": {
      "import": {
        "types": "./dist/precision/index.d.ts",
        "default": "./dist/precision/index.js"
      },
      "require": {
        "types": "./dist/precision/index.d.cts",
        "default": "./dist/precision/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --no-error-on-unmatched-pattern src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "tributario",
    "fiscal",
    "icms",
    "ipi",
    "nfe",
    "nota-fiscal",
    "brasil",
    "precisao",
    "decimal",
    "arredondamento",
    "sefaz"
  ],
  "lint-staged": {
    "*.{ts,js,json,yml,yaml}": "prettier --write"
  },
  "engines": {
    "node": ">=20"
  }
}
